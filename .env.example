# GitHub OAuth App credentials
# Create at: GitHub > Settings > Developer Settings > OAuth Apps > New
# Homepage URL: https://privacy.example.com
# Callback URL: https://privacy.example.com/oauth2/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Generate with: python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
OAUTH2_COOKIE_SECRET=

# Comma-separated GitHub usernames allowed to access the app
GITHUB_ALLOWED_USERS=your-github-username
