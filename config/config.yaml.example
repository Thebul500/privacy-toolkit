# Privacy Toolkit Configuration
# Copy this file to config.yaml and fill in your settings.

web:
  host: "0.0.0.0"
  port: 8080

smtp:
  host: smtp.gmail.com
  port: 587
  use_tls: true
  username: ""              # or set SMTP_USERNAME env var, or use "${SMTP_USERNAME}"
  password: ""              # Gmail App Password — or set SMTP_PASSWORD env var, or use "${SMTP_PASSWORD}"
  from_name: "Privacy Toolkit"
  from_email: ""
  rate_limit: 10            # Max emails per hour
  delay_seconds: 30         # Seconds between emails

browser:
  headless: true
  timeout: 30000
  screenshot_on_submit: true

scheduling:
  rescan_interval_days: 90
  cron_time: "0 3 * * 0"   # Sunday 3 AM
  notify_on_complete: true
  notification_method: signal

notifications:
  signal:
    enabled: false
    api_url: http://signal-api:8080  # or set SIGNAL_API_URL env var
    sender: ""              # or set SIGNAL_SENDER env var
    recipients: []

hibp:
  api_key: ""               # or set HIBP_API_KEY env var — get one at https://haveibeenpwned.com/API/Key

database:
  path: data/privacy_toolkit.db

logging:
  level: INFO
